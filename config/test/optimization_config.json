        "exploration_weight": 0.1
    },
    "logging": {
        "level": "DEBUG",
        "console_output": true,
        "file_output": false
    },
    "data_settings": {
        "use_test_data": true,
        "timeframe": "1day",
        "price_field": "close"
    },
    "metrics": [
        "total_pnl",
        "sharpe_ratio",
        "max_drawdown",
        "win_rate",
        "profit_factor"
