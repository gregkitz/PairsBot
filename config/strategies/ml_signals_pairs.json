      "ratio": 1.0,
      "config": {
        "lookback": 50,
        "hedge_ratio": 1.0,
        "use_rolling_regression": false,
        "entry_threshold": 2.0,
        "exit_threshold": 0.5,
        "stop_loss_threshold": 3.0
      }
    },
    {
      "leg1": "GC", 
